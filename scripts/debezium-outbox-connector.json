{
  "name": "aethercare-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "aethercare",
    "database.password": "aethercare",
    "database.dbname": "aethercare",
    "topic.prefix": "aethercare",
    "slot.name": "aethercare_outbox_slot",
    "publication.name": "aethercare_pub",
    "schema.include.list": "public",
    "table.include.list": "public.outbox_message",
    "plugin.name": "pgoutput",
    "snapshot.mode": "never",
    "tombstones.on.delete": "false",
    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.route.by.field": "target_topic",
    "transforms.outbox.route.topic.replacement": "${routedByValue}",
    "transforms.outbox.table.field.event.id": "id",
    "transforms.outbox.table.field.event.key": "message_key",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.table.fields.additional.placement": "",
    "transforms.outbox.table.expand.json.payload": "true"
  }
}
